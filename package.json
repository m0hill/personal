{
  "name": "personal",
  "version": "1.0.0",
  "description": "Hypermedia-driven Node boilerplate: nub + datastar-kit + oxlint/oxfmt",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "nub run build && concurrently -k --pad-prefix -n css,js,cf -c green,yellow,magenta \"nub run css:watch\" \"nub run client:watch\" \"alchemy dev\"",
    "preview": "nub run build && alchemy dev",
    "deploy": "nub run build && alchemy deploy",
    "destroy": "alchemy destroy",
    "logs": "alchemy logs",
    "tail": "alchemy tail",
    "build": "nub run css:build && nub run client:build",
    "css:build": "tailwindcss -i ./src/styles.css -o ./public/app.css --minify",
    "css:watch": "tailwindcss -i ./src/styles.css -o ./public/app.css --watch",
    "client:build": "nub scripts/build-client.ts",
    "client:watch": "nub scripts/build-client.ts --watch",
    "db:generate": "drizzle-kit generate",
    "db:generate:do": "drizzle-kit generate --config=drizzle.config.do.ts && nub scripts/patch-do-migrations.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/client/tsconfig.json && tsc --noEmit -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "oxlint --type-aware --disable-nested-config",
    "lint:fix": "oxlint --type-aware --fix --disable-nested-config",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "nub run typecheck && nub run lint && nub run format:check && nub run test",
    "prepare": "[ -n \"$CI\" ] || simple-git-hooks"
  },
  "dependencies": {
    "datastar-kit": "^0.4.0",
    "drizzle-orm": "1.0.0-rc.4",
    "effect": ">=4.0.0-beta.84|| >=4.0.0",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "^4.20260629.1",
    "@effect/language-service": "^0.86.2",
    "@effect/platform-bun": "4.0.0-beta.91",
    "@effect/platform-node": "4.0.0-beta.91",
    "@msw/cloudflare": "https://pkg.pr.new/mswjs/cloudflare/@msw/cloudflare@beta",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/cli": "^4.1.0",
    "@types/node": "^26.0.1",
    "alchemy": "2.0.0-beta.59",
    "concurrently": "^9.1.0",
    "drizzle-kit": "1.0.0-rc.4",
    "esbuild": "^0.25.0",
    "lint-staged": "^17.0.8",
    "msw": "^2.14.6",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^7.0.1-rc",
    "vitest": "^4.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "nubx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,md}": [
      "oxfmt"
    ]
  },
  "allowBuilds": {
    "@parcel/watcher": true,
    "esbuild": true,
    "simple-git-hooks": false,
    "workerd": true
  }
}
